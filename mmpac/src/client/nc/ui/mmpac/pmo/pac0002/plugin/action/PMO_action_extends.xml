<?xml version="1.0" encoding="UTF-8"?>
 
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN" "http://www.springframework.org/dtd/spring-beans.dtd">
 
<beans>
	<!-- 间隔按钮 -->
	<bean id="separatorAction" class="nc.funcnode.ui.action.SeparatorAction" />
	
	<!-- 配置卡片界面显示的按钮 actionsOfCard-->
	<!-- <bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		actionsOfCard 或 actionsOfList 
		<property name="actionContainer" ref="actionsOfCard" />
		在何种状态下显示（notedit 或 edit）
		<property name="actionType" value="notedit" />
		表示按钮在界面中的位置
		<property name="target" ref="printActionGroup" />
		 新按钮的位置printActionGroup按钮前/后（before 或 after）
		<property name="pos" value="after" />
		将新按钮的bean放入到按钮扩展类中
		<property name="action" ref="tidaiping" />
	</bean> -->
	
	<!-- 报检 -->
   	<bean id="qccheck"  class="nc.ui.mmpac.pmo.pac0002.action.QCUIAction">
   		<!-- model、editor属性名与按钮类对应 -->
   		<property name="model" ref="manageAppModel" />
		<property name="form" ref="billFormEditor" />
		<property name="list" ref="listView" />
		<!-- 必须属性（不加销售订单维护节点点不开后台报code为null） -->
		<property name="code" value="begin"/>
   	</bean>
   	
   	<!-- 间隔按钮 -->
	<bean id="separatorAction1" class="nc.funcnode.ui.action.SeparatorAction" />
	
   	<!-- 取消报检 -->
   	<bean id="unqccheck"  class="nc.ui.mmpac.pmo.pac0002.action.UnQCUIAction">
   		<!-- model、editor属性名与按钮类对应 -->
   		<property name="model" ref="manageAppModel" />
		<property name="form" ref="billFormEditor" />
		<property name="list" ref="listView" />
		<!-- 必须属性（不加销售订单维护节点点不开后台报code为null） -->
		<property name="code" value="begin"/>
   	</bean>
   	
   	
   	<!--泰华Lims IPC检验-->
   	<bean id="ipc_check"  class="nc.ui.mmpac.pmo.pac0002.action.IPCAction">
   		<!-- model、editor属性名与按钮类对应 -->
   		<property name="model" ref="manageAppModel" />
		<property name="form" ref="billFormEditor" />
		<property name="list" ref="listView" />
		<!-- 必须属性（不加销售订单维护节点点不开后台报code为null） -->
		<property name="code" value="ipcaction"/>
   	</bean>
 
 	<!-- 在打印按钮组后插入间隔按钮 -->
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfList" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="printMenuAction" />
		<property name="pos" value="after" />
		<property name="action" ref="separatorAction" />
	</bean>
 
	<!-- 配置列表界面显示的按钮 actionsOfList-->
	<!-- 在间隔按钮后插入自己的按钮 
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfList" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="separatorAction" />
		<property name="pos" value="after" />
		<property name="action" ref="qccheck" />
	</bean>-->
	
	
 	<!-- 插入间隔按钮 -->
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfList" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="qccheck" />
		<property name="pos" value="after" />
		<property name="action" ref="separatorAction1" />
	</bean>
 
	<!-- 配置列表界面显示的按钮 actionsOfList-->
	<!-- 在间隔按钮后插入自己的按钮 -->
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfList" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="separatorAction1" />
		<property name="pos" value="after" />
		<property name="action" ref="unqccheck" />
	</bean>
	
	<!-- 配置卡片界面显示的按钮 actionsOfCard-->
	<!-- 在打印按钮组后插入间隔按钮 -->
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfCard" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="printMenuAction" />
		<property name="pos" value="after" />
		<property name="action" ref="separatorAction" />
	</bean>
	
	<!-- 在间隔按钮后插入自己的按钮 -->
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfCard" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="separatorAction" />
		<property name="pos" value="after" />
		<property name="action" ref="qccheck" />
	</bean>
	
	
 	<!-- 在打印按钮组后插入间隔按钮 -->
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfCard" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="qccheck" />
		<property name="pos" value="after" />
		<property name="action" ref="separatorAction1" />
	</bean>
 
	<!-- 在间隔按钮后插入自己的按钮 -->
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfCard" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="separatorAction1" />
		<property name="pos" value="after" />
		<property name="action" ref="unqccheck" />
	</bean>
 
	<!-- 在间隔按钮后插入自己的按钮  2022年9月9日 xuchong IPC -->
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfCard" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="unqccheck" />
		<property name="pos" value="after" />
		<property name="action" ref="ipc_check" />
	</bean>
	
		<!-- 预标签打印 -->
   	<bean id="preLabel"  class="nc.ui.mmpac.pmo.pac0002.action.PreLabelPrintAction">
   		<!-- model、editor属性名与按钮类对应 -->
   		<property name="model" ref="manageAppModel" />
		<property name="form" ref="billFormEditor" />
		<property name="list" ref="listView" />
		<!-- 必须属性（不加销售订单维护节点点不开后台报code为null） -->
		<property name="code" value="begin"/>
	</bean>
  	<bean id="TmprintAction" class="nc.ui.mmpac.tmprint.qilisoft.extend.TmprintAction55A2">
		<property name="model" ref="manageAppModel" />
		<property name="editorModel" ref="billFormEditor" />
		<property name="typevalue" value="55A2" />
	</bean>
	
	<bean id="labelActionMenu" class="nc.funcnode.ui.action.MenuAction">
		<property name="name" value="预标签打印" />
		<property name="code" value="labelActionMenu" />
		<property name="actions">
			<list>
				<ref bean="preLabel" />
				<ref bean="TmprintAction" />
			</list>
		</property>
	</bean>
   
   	
   	<!-- 间隔按钮 -->
	<bean id="separatorAction2" class="nc.funcnode.ui.action.SeparatorAction" />
	
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfCard" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="ipc_check" />
		<property name="pos" value="after" />
		<property name="action" ref="separatorAction2" />
	</bean>
	
	<bean class="nc.ui.pubapp.plugin.action.InsertActionInfo">
		<property name="actionContainer" ref="actionsOfCard" />
		<property name="actionType" value="notedit" />
		<property name="target" ref="separatorAction2" />
		<property name="pos" value="after" />
		<property name="action" ref="labelActionMenu" />
	</bean>
</beans>