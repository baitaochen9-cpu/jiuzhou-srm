											<property name="component">
												<ref bean="listView" />
											</property>
										</bean>
									</property>
									<property name="dividerLocation">
										<value>0.2f</value>
									</property>
								</bean>
							</property>
							<property name="dividerLocation">
								<value>30f</value>
							</property>
						</bean>

						<bean class="nc.ui.uif2.tangramlayout.node.VSNode">
							<property name="up">
								<bean class="nc.ui.uif2.tangramlayout.node.CNode">
									<property name="component" ref="cardInfoPnl" />
								</bean>
							</property>
							<property name="down">
