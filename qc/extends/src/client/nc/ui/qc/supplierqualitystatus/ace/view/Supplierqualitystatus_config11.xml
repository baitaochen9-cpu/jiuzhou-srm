									<property name="component" ref="editor" />
								</bean>
							</property>
							<property name="dividerLocation" value="30f" />
						</bean>
					</list>
				</property>
				<property name="showMode" value="CardLayout"></property>
			</bean>
		</property>
	</bean>
	<bean id="container" parent="containerBase" />

