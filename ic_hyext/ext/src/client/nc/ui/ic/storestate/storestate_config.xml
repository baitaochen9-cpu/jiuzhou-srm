<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN//EN" "http://www.springframework.org/dtd/spring-beans.dtd">

<beans>

	<!-- 环境变量 -->
	<bean id="context" class="nc.vo.uif2.LoginContext">
		<property name="nodeType"><value>GROUP_NODE</value></property>
	</bean>

	<!-- 校验模型 -->
	<bean id="validateSerice"
		class="nc.ui.uif2.model.DefaultBatchValidationService">
		<property name="editor" ref="editor" />
	</bean>

	<!-- 模型部分配置########################################################### -->
	<!-- 应用服务类，负责进行模型操作的处理 -->
	<bean id="service" class="nc.ui.pubapp.pub.smart.SmartBatchAppModelService">
		<property name="serviceItf" value="nc.itf.ic.storestate.IStoreStateService"/>
		<property name="voClass" value="nc.vo.ic.storestate.StoreStateVO"/>
	</bean>

	<!-- 对象转换器工厂，由此获取操作对象的特征信息 -->
	<bean id="boadatorfactory" class="nc.vo.bd.meta.BDObjectAdpaterFactory" />
	
	<bean id="templateContainer" class="nc.ui.uif2.editor.TemplateContainer" 
		init-method="load">
		<property name="context" ref="context"></property>
	</bean>
	
	<!-- 批量操作应用模型 -->
	<bean id="appmodel" class="nc.ui.pubapp.uif2app.model.BatchBillTableModel">
		<property name="service" ref="service"></property>
		<property name="businessObjectAdapterFactory" ref="boadatorfactory"></property>
		<property name="context" ref="context"></property>
	</bean>
	<!-- 节点关闭的校验 -->
	<bean id="ClosingListener" class="nc.ui.pubapp.common.validateservice.ClosingCheck">
		<property name="model" ref="appmodel" />
		<property name="saveAction" ref="saveAction" />
	</bean>
	<!-- 数据模型管理器，主要负责各种方式的模型初始化 -->
	<bean id="modelDataManager" class="nc.ui.ic.storestate.model.StoreStateModelDataManager">
		<property name="model" ref="appmodel"></property>
	</bean>
	
	<!-- 界面元素 ###########################################################-->
	<!-- 列表控件 -->
	<bean id="editor" class="nc.ui.pubapp.uif2app.view.BatchBillTable" init-method="initUI">
		<property name="model" ref="appmodel"></property>
		<property name="voClassName" value="nc.vo.ic.storestate.StoreStateVO"/>
  		<property name="componentValueManager">
			<bean class="nc.ui.pubapp.uif2app.view.value.BillCardPanelMetaDataValueAdapter">
  			</bean>
		</property>
	</bean>

	<!-- Actions ###########################################################-->
	<bean id="addAction" class="nc.ui.ic.storestate.action.StorestateAddAction">
		<property name="model"><ref bean="appmodel"/></property>
  		<property name="voClassName" value="nc.vo.ic.storestate.StoreStateVO"/>
	</bean>

	<bean id="editAction" class="nc.ui.pubapp.uif2app.actions.batch.BatchEditAction">
		<property name="model"><ref bean="appmodel"/></property>
	</bean>

	<bean id="deleteAction" class="nc.ui.ic.storestate.action.StorestateDeleteAction">
		<property name="model"><ref bean="appmodel"/></property>
	</bean>
	
	<bean id="saveAction" class="nc.ui.ic.storestate.action.StorestateSaveAction">
		<property name="model" ref="appmodel"/>
		<property name="editor" ref="editor"/>
		<property name="validationService" ref="validateSerice"></property>
	</bean>

	<bean id="cancelAction" class="nc.ui.pubapp.uif2app.actions.batch.BatchCancelAction">
		<property name="model" ref="appmodel"/>
		<property name="editor" ref="editor"/>
	</bean>

	<bean id="refreshAction" class="nc.ui.pubapp.uif2app.actions.batch.BatchRefreshAction">
		<property name="model" ref="appmodel"/>
		<property name="modelManager" ref="modelDataManager"/>
	</bean>
	
	<bean id="enableactiongroup"
		class="nc.funcnode.ui.action.GroupAction">
		<property name="code" value="seal"/>
		<property name="name">
			<bean class="nc.ui.uif2.I18nFB">
				<property name="resDir" value="4008001_0" />
				<property name="resId" value="04008001-0740" />
				<property name="defaultValue" value="封存" />
			</bean>
		</property>	
		<property name="actions">
			<list>
				<ref bean="disableaction" />
				<ref bean="enableaction" />
			</list>
		</property>
	</bean>
	
	<bean id="disableaction" class="nc.ui.ic.storestate.action.StorestateDisableAction">
		<property name="model" ref="appmodel"></property>
	</bean>

	<bean id="enableaction" class="nc.ui.ic.storestate.action.StorestateEnableAction">
		<property name="model" ref="appmodel"></property>
	</bean>
	
	<bean id="printActionGroup" class="nc.funcnode.ui.action.GroupAction">
		<property name="code" value="PrintMenu" />
		<property name="name">
			<bean class="nc.ui.uif2.I18nFB">
				<property name="resDir" value="4008001_0" />
				<property name="resId" value="04008001-0738" />
				<property name="defaultValue" value="打印" />
			</bean>
		</property>
		<property name="actions">
			<list>
				<ref bean="printAction" />
				<ref bean="previewAction" />
				<ref bean="outputAction" />
			</list>
		</property>
	</bean>

	<!-- 模板打印 -->
	<bean id="printAction" class="nc.ui.scmf.pub.ic.action.GeneralMDPrintAction">
		<property name="preview" value="false" />
		<property name="model" ref="appmodel" />
	</bean>
	
	
	<!-- 模板预览 -->
	<bean id="previewAction" class="nc.ui.scmf.pub.ic.action.GeneralMDPreviewAction">
		<property name="preview" value="true" />
		<property name="model" ref="appmodel" />
	</bean>
	
		<!-- 输出 -->
	<bean id="outputAction" class="nc.ui.pubapp.uif2app.actions.OutputAction">
		<property name="model" ref="appmodel" />
		<property name="parent" ref="editor" />
	</bean>
		<!-- 输出
	<bean id="outputAction" class="nc.ui.ic.storestate.action.StorestateOutputAction">
		<property name="model" ref="appmodel" />
		<property name="parent" ref="card" />
	</bean>
	... -->
	

	<!-- 界面布局总装########################################################### -->
	<bean id="container" class="nc.ui.uif2.TangramContainer" init-method="initUI">
		<property name="tangramLayoutRoot">
			<bean class="nc.ui.uif2.tangramlayout.node.CNode">
				<property name="component" ref="editor"></property>
			</bean>
		</property>
		<property name="actions">
			<list>
				<ref bean="addAction" />
				<ref bean="editAction" />
				<ref bean="deleteAction" />
				<bean class="nc.funcnode.ui.action.SeparatorAction" />	
				<ref bean="refreshAction" />
				<bean class="nc.funcnode.ui.action.SeparatorAction" />	
				<ref bean="enableactiongroup" />
				<bean class="nc.funcnode.ui.action.SeparatorAction" />	
				<ref bean="printActionGroup" />
				<bean class="nc.funcnode.ui.action.SeparatorAction" />
				<ref bean="tidaiping"/> 
				<bean class="nc.funcnode.ui.action.SeparatorAction" />
				<ref bean="tidaiping1"/> 
			</list>
		</property>
		<property name="editActions">
			<list>
				<ref bean="addAction" />
				<ref bean="deleteAction" />
				<bean class="nc.funcnode.ui.action.SeparatorAction" />	
				<ref bean="saveAction" />
				<ref bean="cancelAction" />
			</list>
		</property>
		<property name="model" ref="appmodel"/>
	</bean>
	
	<!-- 自己的按钮 -->
   	<bean id="tidaiping"  class="nc.ui.scmf.ic.mbatchcode.action.ElectronicsignatureAction">
   		<!-- model、editor属性名与按钮类对应 -->
   		<property name="model" ref="batchBillTableModel" />
		<property name="editor" ref="editor" />
   	</bean>
   	
   	<!-- 自己的按钮 -->
   	<bean id="tidaiping1"  class="nc.ui.scmf.ic.mbatchcode.action.ElectronicsignatureHisAction">
   		<!-- model、editor属性名与按钮类对应 -->
   		<property name="model" ref="batchBillTableModel" />
		<property name="editor" ref="editor" />
   	</bean>

</beans>
