		<property name="queryAction" ref="queryAction"></property>
		<property name="editor" ref="baseinfoListView"></property>
	</bean>

	<!-- 列表界面分页model -->
	<bean id="paginationModel" class="nc.ui.uif2.components.pagination.PaginationModel"
