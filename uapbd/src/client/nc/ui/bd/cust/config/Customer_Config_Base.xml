<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="context" class="nc.vo.uif2.LoginContext" />

	<bean id="exinfoloader" class="nc.ui.bd.uitabextend.ExinfoLoader">
		<property name="current_md_ID" value="e4f48eaf-5567-4383-a370-a59cb3e8a451" />
	</bean>

	<!-- 扩展点管理 -->
	<bean id="uiTabExtMnger" class="nc.ui.bd.uitabextend.UITabExtManager">
		<property name="targetComponent" ref="baseinfoEditor" />
	</bean>

	<!-- 页签按钮管理 -->
	<bean id="toftpanelActionContributors" class="nc.ui.uif2.actions.ActionContributors">
		<property name="contributors">
			<list>
				<ref bean="baseinfoListViewActions" />
				<ref bean="baseinfoEditorActions" />
			</list>
		</property>
	</bean>
	<!-- 远程调用加载器 -->
	<bean id="remoteCallCombinatorCaller" class="nc.ui.uif2.editor.UIF2RemoteCallCombinatorCaller">
		<property name="remoteCallers">
			<list>
				<ref bean="templateContainer" />
				<ref bean="userdefitemContainer" />
				<ref bean="queryTemplateContainer" />
			</list>
		</property>
	</bean>

	<!-- 模板加载器 -->
	<bean id="templateContainer" class="nc.ui.uif2.editor.TemplateContainer"
		init-method="load">
		<property name="context" ref="context" />
		<property name="nodeKeies">
			<list>
				<value></value>
				<value>share</value>
				<value>createSupplier</value>
				<value>associateSup</value>
			</list>
		</property>
	</bean>
	<!-- 用户定义属性加载器 -->
	<bean id="userdefitemContainer" class="nc.ui.uif2.userdefitem.UserDefItemContainer">
		<property name="context" ref="context" />
		<property name="params">
			<list>
				<bean id="customerUserdefitemParam" class="nc.ui.uif2.userdefitem.QueryParam">
					<property name="mdfullname" value="uap.customer" />
				</bean>
				<bean id="custlinkmanUserdefitemParam" class="nc.ui.uif2.userdefitem.QueryParam">
					<property name="mdfullname" value="uap.custlinkman" />
				</bean>
			</list>
		</property>
	</bean>

	<!-- 查询模板加载器 -->
	<bean id="queryTemplateContainer" class="nc.ui.uif2.editor.QueryTemplateContainer">
		<property name="context" ref="context"></property>
		<property name="nodeKey" value=""></property>
	</bean>

	<bean id="service" class="nc.ui.bd.cust.baseinfo.service.CustBaseInfoModelService">
		<property name="context" ref="context" />
		<property name="extendContext" ref="baseExtendContext"></property>
	</bean>

	<bean id="boadapterfacotry" class="nc.vo.bd.meta.BDObjectAdpaterFactory" />

	<!-- 客户基本信息model -->
	<bean id="baseinfoModel" class="nc.ui.bd.cust.baseinfo.model.CustBaseInfoModel">
		<property name="businessObjectAdapterFactory" ref="boadapterfacotry" />
		<property name="service" ref="service" />
		<property name="context" ref="context" />
	</bean>

