		<property name="context" ref="context" />
		<property name="component1" ref="baseinfoListView" />
		<property name="component2" ref="baseinfoEditor" />
	</bean>

	<!-- 编辑按钮 -->
	<bean id="addAction" class="nc.ui.bd.cust.baseinfo.action.CustBaseInfoAddAction">
