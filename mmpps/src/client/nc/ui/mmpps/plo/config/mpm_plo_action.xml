<?xml version="1.0" encoding="gbk"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">


	<!-- 修改菜单 -->
	<bean id="editActionMenu" class="nc.funcnode.ui.action.GroupAction">
		<property name="actions">
			<list>
				<ref bean="editAction" />
				<ref bean="batchModifyAction" />
			</list>
		</property>
	</bean>

	<!-- 确认菜单 -->
	<bean id="confirmActionMenu" class="nc.funcnode.ui.action.GroupAction">
		<property name="actions">
			<list>
				<ref bean="confirmAction" />
				<ref bean="cancelConfirmAction" />
			</list>
		</property>
	</bean>

	<!-- 完成菜单 -->
	<bean id="overActionMenu" class="nc.funcnode.ui.action.GroupAction">
		<property name="actions">
			<list>
				<ref bean="overAction" />
				<ref bean="cancelOverAction" />
			</list>
		</property>
	</bean>

	<!-- 转出菜单 -->
	<bean id="turnActionMenu" class="nc.funcnode.ui.action.GroupAction">
		<property name="actions">
			<list>
				<ref bean="transferAction" />
				<ref bean="cancelTransferAction" />
			</list>
		</property>
	</bean>

	<!-- 新增 -->
	<bean id="addAction" class="nc.ui.mmpps.plo.action.maintain.PloAddAction">
		<property name="model" ref="manageAppModel" />
		<property name="interceptor" ref="showCardInterceptor" />
		<property name="billForm" ref="billForm" />
	</bean>

	<!-- 卡片显示拦截器 -->
	<bean id="showCardInterceptor1"
		class="nc.ui.pubapp.uif2app.actions.interceptor.ShowUpComponentInterceptor">
		<property name="showUpComponent" ref="listViewEditBillForm" />
	</bean>

	<!-- 删除 -->
	<bean id="deleteAction" class="nc.ui.mmpps.plo.action.maintain.PloDeleteAction">
		<property name="model" ref="manageAppModel" />
		<property name="singleBillService" ref="deleteProxy" />
	</bean>

	<!--保存新增按钮 -->
	<bean id="saveAddAction" class="nc.ui.mmpps.plo.action.maintain.PloSaveAddAction">
		<property name="addAction" ref="addAction"></property>
		<property name="model" ref="manageAppModel" />
		<property name="editor" ref="billForm" />
		<property name="service" ref="maintainProxy" />
	</bean>


	<!-- 保存 -->
	<bean id="saveAction" class="nc.ui.mmpps.plo.action.maintain.PloSaveAction">
		<property name="model" ref="manageAppModel" />
		<property name="editor" ref="billForm" />
		<property name="service" ref="maintainProxy" />
		<property name="validationService" ref="validationService" />
	</bean>

	<!-- 查询 -->
	<bean id="queryAction" class="nc.ui.mmpps.plo.action.PloQueryAction">
		<property name="model" ref="manageAppModel" />
		<property name="dataManager" ref="modelDataManager" />
		<property name="paginationModel" ref="paginationModel" />
		<property name="showUpComponent" ref="listView" />
		<property name="templateContainer" ref="queryTemplateContainer" />
		<property name="qryCondDLGInitializer" ref="qryCondInitializer" />
	</bean>

	<!-- 修改 -->
	<bean id="editAction" class="nc.ui.mmpps.plo.action.maintain.PloEditAction">
		<property name="model" ref="manageAppModel" />
		<property name="editor" ref="billForm" />
		<property name="interceptor" ref="showCardInterceptor" />
	</bean>

	<!-- 批改 -->
	<bean id="batchModifyAction" class="nc.ui.mmpps.plo.action.busi.PloBatchModifyAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>

	<!-- 复制 -->
	<bean id="moCopyAction" class="nc.ui.mmpub.dpub.action.CopyAction">
	<property name="model" ref="manageAppModel" />
		<property name="editor" ref="billForm" />
		<property name="interceptor" ref="showCardInterceptor" />
		<property name="copyActionProcessor">
			<bean class="nc.ui.mmpps.plo.action.maintain.CopyActionProcessor"></bean>
		</property>
	</bean>

	<!-- 订单确认 -->
	<bean id="confirmAction" class="nc.ui.mmpps.plo.action.busi.PloConfirmAction">
		<property name="model" ref="manageAppModel"></property>
		<property name="batchProcessor" ref="batchConfirmProcessor" />
	</bean>

	<!-- 取消确认 -->
	<bean id="cancelConfirmAction" class="nc.ui.mmpps.plo.action.busi.PloCancelConfirmAction">
		<property name="model" ref="manageAppModel"></property>
		<property name="batchProcessor" ref="batchCancelConfirmProcessor" />
	</bean>

	<!-- 订单下达 -->
	<bean id="releaseAction" class="nc.ui.mmpps.plo.action.busi.PloReleaseAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>
	<!-- 产能分流 -->
	<bean id="capacityAction" class="nc.ui.mmpps.plo.action.busi.PloTurnAction">
		<property name="model" ref="manageAppModel" />
		<property name="dialog" ref="PloTurnDialog" />
		<property name="billForm" ref="PloTurnDialogBillForm" />
	</bean>

	<!-- 订单完成 -->
	<bean id="overAction" class="nc.ui.mmpps.plo.action.busi.PloOverAction">
		<property name="model" ref="manageAppModel"></property>
		<property name="batchProcessor" ref="batchOverProcessor" />
	</bean>

	<!-- 取消完成 -->
	<bean id="cancelOverAction" class="nc.ui.mmpps.plo.action.busi.PloCancelOverAction">
		<property name="model" ref="manageAppModel"></property>
		<property name="batchProcessor" ref="batchCancelOverProcessor" />
	</bean>

	<!-- 转出 -->
	<bean id="transferAction" class="nc.ui.mmpps.plo.action.busi.PloTransferAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>

	<!-- 取消转出 -->
	<bean id="cancelTransferAction" class="nc.ui.mmpps.plo.action.busi.PloCancelTransferAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>

	<!-- 合并菜单 -->
	<bean id="combineBillActionMenu" class="nc.funcnode.ui.action.GroupAction">
		<property name="actions">
			<list>
				<ref bean="combineBillAction" />
				<ref bean="cancelcombineBillAction" />
				<ref bean="combineSchemeAction" />
			</list>
		</property>
	</bean>
	<!-- 合并 -->
	<bean id="combineBillAction" class="nc.ui.mmpps.plo.action.busi.PloCombineBillAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>
	<!-- 合并方案 -->
	<bean id="combineSchemeAction" class="nc.ui.mmpps.plo.action.busi.PloCombineSchemeAction">
		<property name="model" ref="manageAppModel"></property>
		<property name="billForm" ref="billForm"></property>
	</bean>
	<!-- 取消合并 -->
	<bean id="cancelcombineBillAction" class="nc.ui.mmpps.plo.action.busi.PloCancelCombineBillAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>

	<!-- 预留子项维护 -->
	<bean id="ReservesubsupplyAction" class="nc.ui.mmpps.plo.action.busi.PloReservesubsupplyAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>

	<!-- 需求跟踪矩阵 -->
	<bean id="demandTraceAction" class="nc.ui.mmpps.plo.action.busi.PloDemandTraceAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>

	<!-- 供给影响分析 -->
	<bean id="supplyEffectiveAction" class="nc.ui.mmpps.plo.action.busi.PloSupplyEffectiveAction">
		<property name="model" ref="manageAppModel"></property>
	</bean>
	<!-- 联查单据 -->
	<bean id="joinQueryAction" class="nc.ui.pubapp.uif2app.actions.LinkQueryAction">
	<property name="model" ref="manageAppModel" />
		<property name="billType" value="55B4" />
		<property name="openMode" value="1" />
	</bean>
	<!-- 联查下游 主生产计划/流程生产订单/离散生产订单 -->
	<!-- 此处逻辑改在分别配置到mpsmrp各自的config，因为mrp没有下游主生产计划 -->
	<bean id="mpsTargetBillTypeQueryMenu" class="nc.funcnode.ui.action.MenuAction">
		<property name="code" value="targetBillTypeQuery" />
		<property name="name">
			<bean class="nc.ui.uif2.I18nFB">
				<property name="resDir" value="50010006_0" />
				<property name="resId" value="050010006-1022" />
				<property name="defaultValue" value="下游单据" />
			</bean>
		</property>
		<property name="actions">
			<list>
				<ref bean="queryTargetMPSAction" />
				<ref bean="queryTargetMOAction" />
			</list>
		</property>
	</bean>
	<bean id="mrpTargetBillTypeQueryMenu" class="nc.funcnode.ui.action.MenuAction">
		<property name="code" value="targetBillTypeQuery" />
		<property name="name">
			<bean class="nc.ui.uif2.I18nFB">
				<property name="resDir" value="50010006_0" />
				<property name="resId" value="050010006-1022" />
				<property name="defaultValue" value="下游单据" />
			</bean>
		</property>
		<property name="actions">
			<list>
				<!--MRP没有主生产计划下游 -->
				<ref bean="queryTargetMOAction" />
			</list>
		</property>
	</bean>
	<!--主生产计划 -->
	<bean id="queryTargetMPSAction" class="nc.ui.mmpps.plo.action.busi.PloQueryTargetMPSAction">
		<property name="model" ref="manageAppModel" />
	</bean>
	<!--生产订单 -->
	<bean id="queryTargetMOAction" class="nc.ui.mmpps.plo.action.busi.PloQueryTargetMOAction">
		<property name="model" ref="manageAppModel" />
	</bean>

	<!-- 导入导出按钮 -->
	<bean id="importExportMenu" class="nc.funcnode.ui.action.MenuAction">
		<property name="code" value="importExport" />
		<property name="name">
			<bean class="nc.ui.uif2.I18nFB">
				<property name="resDir" value="50010006_0" />
				<property name="resId" value="050010006-1015" />
				<property name="defaultValue" value="导入导出" />
			</bean>
		</property>
		<property name="actions">
			<list>
				<ref bean="ImportData" />	<!-- 导入Excel -->
				<ref bean="separatorAction" />
				<ref bean="ExportData" />	 <!--导出Excel -->
				<ref bean="ExportTemplate" />  <!--导出模板 -->
			</list>
		</property>
	</bean>

	<!-- 导入Excel（根据模板填充数据） -->
	<bean id="ImportData" class="nc.ui.mmpub.pub.action.MMImportDataAction">
		<property name="model" ref="manageAppModel" />
		<property name="importableEditor" ref="ImportExportEditor" />
	</bean>

	<!-- 导出模板到Excel -->
	<bean id="ExportTemplate" class="nc.ui.mmpub.pub.action.MMExportTemplateAction">
		<property name="model" ref="manageAppModel" />
		<property name="importableEditor" ref="ImportExportEditor" />
	</bean>

	<!-- 导入项目编辑器 -->
	<bean id="ImportExportEditor" class="nc.ui.mmpps.plo.action.PloImportableEditor">
		<property name="billcardPanelEditor" ref="billForm" />
		<property name="addAction" ref="addAction" />
		<property name="cancelAction" ref="cancelAction" />
		<property name="saveAction" ref="ImportAction" />
		<property name="appModel" ref="manageAppModel" />
		<property name="processor" ref="voProcesor" />
	</bean>

	<bean id="voProcesor" class="nc.ui.mmpps.plo.action.PloVOImportProcessor">
		<property name="billForm" ref="billForm" />
		<property name="model" ref="manageAppModel" />
	</bean>

	<!-- 导入保存处理 -->
	<bean id="ImportAction" class="nc.ui.mmpps.plo.action.maintain.PloImportAction">
		<property name="model" ref="manageAppModel" />
		<property name="editor" ref="billForm" />
		<property name="service" ref="maintainProxy" />
	</bean>

	<!-- 导出数据到Excel -->
	<bean id="ExportData" class="nc.ui.mmpps.plo.action.PloExportAction">
		<property name="model" ref="manageAppModel" />
		<property name="importableEditor" ref="ImportExportEditor" />
	</bean>

	<!-- 打印按钮组 -->
	<bean id="printMenuAction" class="nc.funcnode.ui.action.GroupAction">
		<property name="code" value="printMenuAction" />
		<property name="name" value="打印" />
		<property name="actions">
			<list>
				<ref bean="printAction" />
				<ref bean="previewAction" />
				<ref bean="outputAction" />
			</list>
		</property>
	</bean>

	<!-- 打印 -->
	<!-- <bean id="printAction" class="nc.ui.pubapp.uif2app.actions.MetaDataBasedPrintAction"> -->
	<!-- <property name="preview" value="false" /> -->
	<!-- <property name="model" ref="manageAppModel" /> -->
	<!-- <property name="beforePrintDataProcess" ref="beforePrintDataProcess" 
		/> -->
	<!-- </bean> -->
	<bean id="printAction" class="nc.ui.mmpps.plo.print.PrintAction">
		<constructor-arg index="0" value="true" />
		<property name="model" ref="manageAppModel" />
		<property name="listView" ref="listView" />
		<property name="billForm" ref="billForm" />
	</bean>

	<!-- 预览 -->
	<!-- <bean id="previewAction" class="nc.ui.pubapp.uif2app.actions.MetaDataBasedPrintAction"> -->
	<!-- <property name="preview" value="true" /> -->
	<!-- <property name="model" ref="manageAppModel" /> -->
	<!-- <property name="beforePrintDataProcess" ref="beforePrintDataProcess" 
		/> -->
	<!-- </bean> -->
	<bean id="previewAction" class="nc.ui.mmpps.plo.print.PrintAction">
		<constructor-arg index="0" value="false" />
		<property name="model" ref="manageAppModel" />
		<property name="listView" ref="listView" />
		<property name="billForm" ref="billForm" />
	</bean>

	<!-- 输出 -->
	<bean id="outputAction" class="nc.ui.mmpps.plo.print.PloOutputAction">
		<property name="model" ref="manageAppModel" />
		<property name="parent" ref="billForm" />
		<property name="listView" ref="listView" />
		<property name="billForm" ref="billForm" />
	</bean>
	<!-- 打印精度处理 -->
	<bean id="beforePrintDataProcess" class="nc.ui.mmpps.plo.sacle.BeforePrintDataProcess">
		<property name="model" ref="manageAppModel" />
	</bean>

	<!-- 服务开始 -->
	<!-- 取消确认服务 -->
	<bean id="batchCancelConfirmProcessor" class="nc.ui.mmf.framework.batch.MultiBatchProcessor">
		<property name="model" ref="manageAppModel" />
		<property name="service" ref="batchCancelConfirmService" />
	</bean>

	<bean id="batchCancelConfirmService" class="nc.ui.mmpps.plo.serviceproxy.PloCancelConfirmProxy" />

	<!-- 取消完成服务 -->
	<bean id="batchCancelOverProcessor" class="nc.ui.mmf.framework.batch.MultiBatchProcessor">
		<property name="model" ref="manageAppModel" />
		<property name="service" ref="batchCancelOverService" />
	</bean>

	<bean id="batchCancelOverService" class="nc.ui.mmpps.plo.serviceproxy.PloCancelOverProxy" />

	<!-- 确认服务 -->
	<bean id="batchConfirmProcessor" class="nc.ui.mmf.framework.batch.MultiBatchProcessor">
		<property name="model" ref="manageAppModel" />
		<property name="service" ref="batchConfirmService" />
	</bean>

	<bean id="batchConfirmService" class="nc.ui.mmpps.plo.serviceproxy.PloConfirmProxy" />

	<!-- 完成服务 -->
	<bean id="batchOverProcessor" class="nc.ui.mmf.framework.batch.MultiBatchProcessor">
		<property name="model" ref="manageAppModel" />
		<property name="service" ref="batchOverService" />
	</bean>

	<bean id="batchOverService" class="nc.ui.mmpps.plo.serviceproxy.PloOverProxy" />

	<!-- 服务结束 -->

	<!-- 校验服务 -->
	<bean id="validationService" class="nc.ui.pubapp.uif2app.validation.CompositeValidation">
		<property name="validators">
			<list>
				<bean class="nc.ui.pubapp.uif2app.validation.TemplateNotNullValidation">
					<property name="billForm" ref="billForm" />
				</bean>


			</list>
		</property>
	</bean>

</beans>
