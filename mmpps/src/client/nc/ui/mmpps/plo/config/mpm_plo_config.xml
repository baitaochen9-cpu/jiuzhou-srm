<?xml version="1.0" encoding="gbk"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!--引用配置文件基类 -->
	<import resource="classpath:/nc/ui/mmf/framework/config/general_config.xml" />
	<import resource="classpath:/nc/ui/mmf/framework/config/general_userdef.xml" />

	<!--按钮配置类 -->
	<import resource="classpath:/nc/ui/mmpps/plo/config/mpm_plo_dialog.xml" />
	<import resource="classpath:/nc/ui/mmpps/plo/config/mpm_plo_event.xml" />
	<import resource="classpath:/nc/ui/mmpps/plo/config/mpm_plo_listedit_config.xml" />

	<!-- 单据操作代理 -->
	<bean id="maintainProxy" class="nc.ui.mmpps.plo.serviceproxy.PloMaintainServiceProxy" />

	<!-- 查询模板加载 -->
	<bean id="queryTemplateContainer" class="nc.ui.uif2.editor.QueryTemplateContainer">
		<property name="context" ref="context" />
	</bean>

	<!-- 单据查询代理 -->
	<bean id="queryProxy" class="nc.ui.mmpps.plo.serviceproxy.AcePoQueryServiceProxy">
		<property name="model" ref="manageAppModel" />
	</bean>

	<!-- 单据删除代理，支持批操作 -->
	<bean id="deleteProxy" class="nc.ui.mmpps.plo.serviceproxy.AcePoDeleteProxy" />

	<!-- 打开节点监听 -->
	<bean id="InitDataListener"
		class="nc.ui.pubapp.uif2app.model.DefaultFuncNodeInitDataListener">
		<!-- 打开节点节点后要显示的界面 -->
		<property name="queryAction" ref="queryAction" />
		<property name="model" ref="manageAppModel" />
		<!-- VO的类名 -->
		<property name="voClassName" value="nc.vo.mmpps.mps0202.PoVO" />
		<property name="autoShowUpComponent" ref="billForm" />
		<property name="processorMap">
			<map>
				<!-- 计划员工作台打开或者MPS/MRP运算 -->
				<entry key="1">
					<bean
						class="nc.ui.mmpps.plo.billref.processor.PloFuncNodeInitDataListener">
						<property name="model" ref="manageAppModel" />
						<property name="listview" ref="listView" />
						<property name="billform" ref="billForm" />
						<property name="saveAction" ref="saveAction" />
						<property name="paginationModel" ref="paginationModel" />
					</bean>
				</entry>
				<!-- 粗能力根据主键集合打开计划订单 -->
				<entry key="6">
					<bean class="nc.ui.mmpps.plo.billref.processor.InitDataProcessorForRCCP">
						<property name="model" ref="manageAppModel" />
						<property name="listview" ref="listView" />
					</bean>
				</entry>
				<!-- 关键料驱动生产批产推单V6.1 -->
				<entry key="3">
					<bean class="nc.ui.mmpps.plo.billref.processor.InitDataProcessorForKMD">
						<property name="transferProcessor" ref="transferViewProcessor" />
						<property name="billfrom" ref="billForm" />
					</bean>
				</entry>
				<!-- 实际独立需求推单V6.1 -->
				<entry key="4">
					<bean class="nc.ui.mmpps.plo.billref.processor.InitDataProcessorForAID">
						<property name="transferProcessor" ref="transferViewProcessor" />
						<property name="billfrom" ref="billForm" />
					</bean>
				</entry>
				<!-- 计划独立需求推单V6.1 -->
				<entry key="5">
					<bean class="nc.ui.mmpps.plo.billref.processor.InitDataProcessorForPID">
						<property name="transferProcessor" ref="transferViewProcessor" />
						<property name="billfrom" ref="billForm" />
					</bean>
				</entry>
				<!--为工程变更单提供的初始化监听 -->
				<entry key="002">
					<bean class="nc.ui.mmpps.plo.billref.processor.InitDataProcessorForECN">
						<property name="listview" ref="listView" />
						<property name="billform" ref="billForm" />
						<!--<property name="transferProcessor" ref="transferBillViewProcessor" 
							/> -->
					</bean>
				</entry>
				<!-- 推单V6.5 -->
				<entry key="7">
					<bean class="nc.ui.mmpps.plo.billref.processor.InitDataProcessorForPPM">
						<property name="transferProcessor" ref="transferViewProcessor" />
						<property name="billfrom" ref="billForm" />
					</bean>
				</entry>
			</map>
		</property>
	</bean>
	<!-- 远程调用加载器 <bean id="remoteCallCombinatorCaller" class="nc.ui.uif2.editor.UIF2RemoteCallCombinatorCaller"> 
		<property name="remoteCallers"> <list> <ref bean="templateContainer" /> <ref 
		bean="userdefitemContainer" /> <ref bean="queryTemplateContainer" /> </list> 
		</property> </bean> -->
	<!-- 界面布局总装 -->
	<bean id="container" class="nc.ui.uif2.TangramContainer"
		init-method="initUI">
		<property name="model" ref="manageAppModel" />
		<property name="tangramLayoutRoot">
			<bean class="nc.ui.uif2.tangramlayout.node.TBNode">
				<property name="showMode" value="CardLayout" />
				<property name="tabs">
					<list>
						<bean class="nc.ui.uif2.tangramlayout.node.HSNode">
							<property name="left">
								<bean class="nc.ui.uif2.tangramlayout.node.CNode">
									<property name="component" ref="queryArea" />
								</bean>
							</property>
							<property name="right">
								<bean class="nc.ui.uif2.tangramlayout.node.VSNode">
									<property name="up">
										<bean class="nc.ui.uif2.tangramlayout.node.CNode">
											<property name="component" ref="queryInfo" />
										</bean>
									</property>
									<property name="down">
										<bean class="nc.ui.uif2.tangramlayout.node.CNode">
											<property name="name" value="列表" />
											<property name="component" ref="listView" />
										</bean>
									</property>
									<property name="dividerLocation" value="25f" />
								</bean>
							</property>
							<property name="dividerLocation" value="0.22f" />
						</bean>
						<bean class="nc.ui.uif2.tangramlayout.node.VSNode">
							<property name="up">
								<bean class="nc.ui.uif2.tangramlayout.node.CNode">
									<property name="component" ref="cardInfoPnl" />
								</bean>
							</property>
							<property name="down">
								<bean class="nc.ui.uif2.tangramlayout.node.CNode">
									<property name="name" value="卡片" />
									<property name="component" ref="billForm" />
								</bean>
							</property>
							<property name="dividerLocation" value="30f" />
						</bean>
						<bean class="nc.ui.uif2.tangramlayout.node.CNode">
							<property name="component" ref="listViewEditBillForm"></property>
						</bean>
					</list>
				</property>
			</bean>
		</property>
	</bean>

	<!-- 列表界面 -->
	<bean id="listView" class="nc.ui.mmpps.plo.view.PloListView"
		init-method="initUI">
		<property name="multiSelectionEnable" value="true" />
		<property name="model" ref="manageAppModel"></property>
		<property name="templateContainer" ref="templateContainer"></property>
		<property name="showTotalLine" value="true" />
		<!-- 列表自定义项处理 -->
		<property name="userdefitemListPreparator">
			<bean class="nc.ui.pubapp.uif2app.view.CompositeBillListDataPrepare">
				<property name="billListDataPrepares">
					<list>
						<ref bean="userdefitemlistPreparator" />
						<ref bean="pmarAsstPreparator" />
						<ref bean="marAsstPreparator" />
					</list>
				</property>
			</bean>
		</property>
		<property name="south" ref="paginationBar" />
	</bean>



	<!-- 列表自定义项处理 -->
	<bean name="userdefitemlistPreparator" class="nc.ui.uif2.editor.UserdefitemContainerListPreparator">
		<property name="container" ref="userdefitemContainer" />
		<property name="params">
			<list>
				<bean class="nc.ui.uif2.editor.UserdefQueryParam">
					<property name="mdfullname" value="pd.mm_plo" />
					<property name="pos" value="0" />
					<property name="prefix" value="vdef" />
				</bean>
			</list>
		</property>
	</bean>

	<!-- 卡片界面 -->
	<bean id="billForm" class="nc.ui.mmpps.plo.view.PloBillForm"
		init-method="initUI">
		<property name="model" ref="manageAppModel"></property>
		<property name="templateContainer" ref="templateContainer" />
		<property name="showOrgPanel" value="true" />
		<property name="showTotalLine" value="false" />
		<!-- 卡片自定义项处理 -->
		<property name="userdefitemPreparator">
			<bean class="nc.ui.pubapp.uif2app.view.CompositeBillDataPrepare">
				<property name="billDataPrepares">
					<list>
						<ref bean="userdefitemPreparator" />
						<ref bean="pmarAsstPreparator" />
						<ref bean="marAsstPreparator" />
					</list>
				</property>
			</bean>
		</property>
	</bean>

	<!-- 卡片自定义项配置 -->
	<bean name="userdefitemPreparator" class="nc.ui.uif2.editor.UserdefitemContainerPreparator">
		<property name="container" ref="userdefitemContainer" />
		<property name="params">
			<list>
				<bean class="nc.ui.uif2.editor.UserdefQueryParam">
					<property name="mdfullname" value="pd.mm_plo" />
					<property name="pos" value="0" />
					<property name="prefix" value="vdef" />
				</bean>
			</list>
		</property>
	</bean>

	<!-- 物料辅助属性组件配置 -->
	<bean id="marAsstPreparator"
		class="nc.ui.pubapp.uif2app.view.material.assistant.MarAsstPreparator">
		<property name="model" ref="manageAppModel" />
		<property name="container" ref="userdefitemContainer" />
		<property name="prefix" value="vfree" />
		<property name="materialField" value="cmaterialvid" />
		<property name="projectField" value="cprojectid" />
		<property name="supplierField" value="cvendorid" />
		<property name="productorField" value="cproductorid" />
		<property name="customerField" value="ccustomid" />
		<property name="signatureField" value="cffileid" />
	</bean>

	<!-- 父项物料辅助属性组件配置 -->
	<bean id="pmarAsstPreparator"
		class="nc.ui.pubapp.uif2app.view.material.assistant.MarAsstPreparator">
		<property name="model" ref="manageAppModel" />
		<property name="container" ref="userdefitemContainer" />
		<property name="prefix" value="vpfree" />
		<property name="materialField" value="cpmaterialvid" />
		<property name="projectField" value="cpprojectid" />
		<property name="supplierField" value="cpvendorid" />
		<property name="productorField" value="cpproductorid" />
		<property name="customerField" value="cpcustomid" />
		<property name="signatureField" value="cpffileid" />
	</bean>

	<!-- 用户自定义项容器 -->
	<bean id="userdefitemContainer" class="nc.ui.uif2.userdefitem.UserDefItemContainer">
		<property name="context" ref="context" />
		<property name="params">
			<list>
				<bean class="nc.ui.uif2.userdefitem.QueryParam">
					<property name="mdfullname" value="pd.mm_plo" />
				</bean>
				<bean class="nc.ui.uif2.userdefitem.QueryParam">
					<property name="rulecode" value="materialassistant" />
				</bean>
			</list>
		</property>
	</bean>

	<!-- 模型数据管理类，用于模型初始化，继承自父亲基本信息 <property name="model" ref="manageAppModel" 
		/> -->
	<bean id="modelDataManager" class="nc.ui.mmpps.plo.model.PloModelManager">
		<property name="paginationModel" ref="paginationModel" />
		<property name="model" ref="manageAppModel" />
	</bean>

	<!-- 模板容器，负责对模板的统一装载 -->
	<bean id="templateContainer" class="nc.ui.pubapp.uif2app.view.TemplateContainer">
		<property name="context" ref="context" />
		<property name="nodeKeies">
			<list>
				<value>500400A7</value>
				<value>5004000601</value>
				<value>5004000602</value>
				<value>5006000601</value>
				<value>5006000602</value>
				<value>5006000603</value>
				<value>5004000603</value>
				<value>5006000604</value>
			</list>
		</property>
	</bean>



	<!-- 转单后公共代码处理 -->
	<bean id="transferViewProcessor" class="nc.ui.mmpps.plo.action.PloTransferProcessor">
		<property name="list" ref="listView" />
		<!-- 列表按钮容器 -->
		<property name="actionContainer" ref="actionsOfList" />
		<!-- 卡片按钮容器 -->
		<property name="cardActionContainer" ref="actionsOfCard" />
		<!-- 单据保存按钮 -->
		<property name="saveAction" ref="saveAction" />
		<!-- 单据取消按钮 -->
		<property name="cancelAction" ref="cancelAction" />
		<property name="billForm" ref="billForm" />
		<property name="transferLogic">
			<bean class="nc.ui.pubapp.billref.dest.DefaultBillDataLogic">
				<property name="billForm" ref="billForm" />
			</bean>
		</property>
	</bean>

	<!-- 自动修正卡片界面的分数显示控件(换算率) -->
	<bean id="fractionFixMediator" class="nc.ui.pubapp.uif2app.view.FractionFixMediator">
		<constructor-arg ref="billForm" />
		<constructor-arg ref="listView" />
		<property name="keys">
			<list>
				<value>vchangerate</value>
			</list>
		</property>
	</bean>

	<!-- model与界面的表体排序同步组件<bean id="billBodySortMediator" parent="abstractBodySort"/> -->

	<!-- 设置单据号可编辑性 -->
	<bean id="billCodeMediator" class="nc.ui.pubapp.bill.BillCodeMediator">
		<property name="billCodeKey" value="vbillcode"></property>
		<property name="billType" value="55B4"></property>
	</bean>

	<!--用于销售订单号超链接 -->
	<bean id="soQueryHyperlinkMediator"
		class="nc.ui.mmf.framework.handler.MMLinkQueryHyperlinkMediator">
		<property name="model" ref="manageAppModel" />
		<property name="srcBillIdField" value="vsrcid" />
		<!-- 超链字段名 -->
		<property name="srcBillNOField" value="vsalebillcode" />
		<!-- 保存源单据类型的字段名 -->
		<property name="srcBillType" value="30" />
		<!-- 保存源单据类型的字段所在位置，0：表头；1：表体 -->
		<property name="srcBillTypeFieldPos" value="0" />
	</bean>

	<!--用于来源单据号超链接 -->
	<bean id="srcQueryHyperlinkMediator" class="nc.ui.mmpps.plo.linkquery.PloLinkQueryHyperlinkMediator">
		<property name="model" ref="manageAppModel" />
		<property name="srcBillIdField" value="vsrcid" />
		<!-- 超链字段名 -->
		<property name="srcBillNOField" value="vsrccode" />
		<!-- 保存源单据类型的字段名 -->
		<property name="srcBillTypeField" value="vsrctype" />
		<!-- 保存源单据类型的字段所在位置，0：表头；1：表体 -->
		<property name="srcBillTypeFieldPos" value="0" />
	</bean>

	<!--用于源头单据号超链接 -->
	<bean id="firstQueryHyperlinkMediator" class="nc.ui.mmpps.plo.linkquery.PloLinkQueryHyperlinkMediator">
		<property name="model" ref="manageAppModel" />
		<property name="srcBillIdField" value="vfirstid" />
		<!-- 超链字段名 -->
		<property name="srcBillNOField" value="vfirstcode" />
		<!-- 保存源单据类型的字段名 -->
		<property name="srcBillTypeField" value="vfirsttype" />
		<!-- 保存源单据类型的字段所在位置，0：表头；1：表体 -->
		<property name="srcBillTypeFieldPos" value="0" />
	</bean>

	<!--用于计划订单号超链接 -->
	<bean id="ploQueryHyperlinkMediator" class="nc.ui.mmpps.plo.view.PloMouseClickShowPanelMediator">
		<property name="listView" ref="listView" />
		<property name="showUpComponent" ref="billForm" />
		<property name="hyperLinkColumn" value="vbillcode" />
	</bean>

	<!-- 计划产出数量与计划投入数量互算 -->
	<bean id="scrapFactoryVO" class="nc.vo.mmpub.pub.scraptfactor.param.ScrapFactorParam">
		<property name="naccoutnum" value="nnumber" />
		<property name="nassaccoutnum" value="nastnum" />
	</bean>

	<!-- 分页面板 -->
	<bean id="paginationBar" class="nc.ui.uif2.components.pagination.PaginationBar"
		init-method="registeCallbak">
		<property name="paginationModel" ref="paginationModel" />
		<property name="context" ref="context" />
	</bean>

	<!-- 分页model -->
	<bean id="paginationModel" class="nc.ui.uif2.components.pagination.PaginationModel"
		init-method="init">
		<property name="paginationQueryService" ref="queryProxy" />
	</bean>

	<!-- 分页按钮条 -->
	<bean id="pcardInfoPnl" class="nc.ui.uif2.tangramlayout.CardLayoutToolbarPanel">
		<property name="actions">
			<list>
				<bean id="accessoryShowAction" class="nc.ui.bd.pub.actions.AccessoryAction">
					<property name="model" ref="manageAppModel" />
					<property name="showOnly" value="true" />
					<property name="metaDataID" value="458fae9b-c6ac-44f6-b825-0419430b8ad4" />
				</bean>
				<bean id="actionsBarSeparator" class="nc.ui.pub.beans.ActionsBar$ActionsBarSeparator" />
				<bean id="firstLineAction" class="nc.ui.uif2.actions.FirstLineAction">
					<property name="model" ref="manageAppModel" />
					<property name="exceptionHandler" ref="defaultExceptionHandler" />
				</bean>
				<bean id="preLineAction" class="nc.ui.uif2.actions.PreLineAction">
					<property name="model" ref="manageAppModel" />
					<property name="exceptionHandler" ref="defaultExceptionHandler" />
				</bean>
				<bean id="nextLineAction" class="nc.ui.uif2.actions.NextLineAction">
					<property name="model" ref="manageAppModel" />
					<property name="exceptionHandler" ref="defaultExceptionHandler" />
				</bean>
				<bean id="lastLineAction" class="nc.ui.uif2.actions.LastLineAction">
					<property name="model" ref="manageAppModel" />
					<property name="exceptionHandler" ref="defaultExceptionHandler" />
				</bean>
			</list>
		</property>
		<property name="titleAction">
			<bean id="preturnaction" class="nc.ui.uif2.actions.ShowMeUpAction">
				<property name="goComponent" ref="listView" />
			</bean>
		</property>
		<property name="model" ref="manageAppModel" />
	</bean>

	<bean id="defaultExceptionHandler" class="nc.ui.uif2.DefaultExceptionHanler">
		<property name="context" ref="context"></property>
	</bean>

	<!-- 查询框初始化 -->
	<bean id="qryCondInitializer" class="nc.ui.mmpps.plo.query.PloQryCondDLGiInitializer">
		<property name="model" ref="manageAppModel" />
	</bean>

	<bean id="rowNoMediator" class="nc.ui.mmpps.plo.view.RowNoMediator">
		<property name="model" ref="manageAppModel" />
		<property name="rowNoKeys">
			<list>
				<value>vfirstrowno</value>
				<value>vsrcrowno</value>
			</list>
		</property>
	</bean>
	<!--用于生产bom版本号超链接 -->
	<bean id="bomQueryHyperlinkMediator"
		class="nc.ui.mmf.framework.handler.MMLinkQueryHyperlinkMediator">
		<property name="model" ref="manageAppModel" />
		<property name="srcBillIdField" value="cbomid" />
		<!-- 超链字段id -->
		<property name="srcBillNOField" value="cbomid" />
		<!-- 源单据类型 -->
		<property name="srcBillType" value="19B1" />
		<!--源单据类型的字段所在位置，0：表头；1：表体 -->
		<property name="srcBillTypeFieldPos" value="0" />
	</bean>
	<!--用于包装bom版本号超链接 -->
	<bean id="bomPackQueryHyperlinkMediator"
		class="nc.ui.mmf.framework.handler.MMLinkQueryHyperlinkMediator">
		<property name="model" ref="manageAppModel" />
		<property name="srcBillIdField" value="cpackbomid" />
		<!-- 超链字段id -->
		<property name="srcBillNOField" value="cpackbomid" />
		<!-- 源单据类型 -->
		<property name="srcBillType" value="19B1" />
		<!--源单据类型的字段所在位置，0：表头；1：表体 -->
		<property name="srcBillTypeFieldPos" value="0" />
	</bean>
	<!--用于工艺路线版本号超链接 -->
	<bean id="rtQueryHyperlinkMediator"
		class="nc.ui.mmf.framework.handler.MMLinkQueryHyperlinkMediator">
		<property name="model" ref="manageAppModel" />
		<property name="srcBillIdField" value="crtid" />
		<!-- 超链字段名 -->
		<property name="srcBillNOField" value="crtid" />
		<!-- 源单据类型 -->
		<property name="srcBillType" value="19B2" />
		<!--源单据类型的字段所在位置，0：表头；1：表体 -->
		<property name="srcBillTypeFieldPos" value="0" />
	</bean>

</beans>
